#!/bin/csh -f

#
# default configuration file
#

source ${SETLOAD}/Configuration

setenv SETMODE		load
#setenv SETMODE		preview

setenv LOADDIR          /data/loads/mgi/rnaseqload/setload
setenv SETOUTPUTDIR     ${LOADDIR}
setenv SETDATADIR       ${LOADDIR}
setenv SETINPUTFILE	${SETDATADIR}/diffsetload.txt
setenv SETLOG		${SETDATADIR}/diffsetload.log
setenv SETNAME		"RNASeq Load Experiments"
setenv SETTYPE		"GXD HT Experiment"  # MGI Type
setenv CREATEDBY	"cms"
